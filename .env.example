# Qdrant connection URL (used for local dev outside Docker)
QDRANT_URL=http://localhost:6333

# Absolute path to your Obsidian vault directory
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
# Optional explicit vault name for Obsidian URI deep links.
# Use this if your Obsidian vault display name differs from the folder name.
# OBSIDIAN_VAULT_NAME=My Vault

# Port configuration (optional - customize to avoid conflicts with other services)
# SBI_API_PORT=8000
# SBI_QDRANT_HTTP_PORT=6333
# SBI_QDRANT_GRPC_PORT=6334

# File watcher mode (optional)
# Set to "true" to use PollingObserver instead of native OS events.
# Required inside Docker on macOS where bind-mount events don't propagate.
# docker-compose.yml sets this to "true" automatically.
# USE_POLLING_OBSERVER=false
# POLLING_INTERVAL_SECONDS=3.0

# Scheduled incremental rebuild (optional)
# SCHEDULED_REBUILD_ENABLED=true       # Disable to turn off daily cron rebuild
# STARTUP_INCREMENTAL_REBUILD=true     # Run incremental rebuild on app startup
# REBUILD_CRON_HOUR=3                  # UTC hour for daily rebuild (default: 03:00)
# REBUILD_CRON_MINUTE=0                # UTC minute for daily rebuild
# HASH_REGISTRY_DATA_PATH=/data        # Directory for hash_registry.json persistence
